{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "ESP32 IoT Station",
  "uid": "esp32-iot-station",
  "tags": ["esp32", "iot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Température (°C)",
      "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
          "query": "from(bucket: \"iot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temp\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Humidité (%)",
      "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "humidity" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
          "query": "from(bucket: \"iot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"humidity\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dernière température",
      "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
          "query": "from(bucket: \"iot\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temp\")\n  |> last()"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Messages reçus (10 min) — robustesse",
      "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
          "query": "from(bucket: \"iot\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r._measurement == \"environment\" and r._field == \"temp\")\n  |> count()"
        }
      ]
    }
  ]
}
